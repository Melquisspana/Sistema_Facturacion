APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Seguridad (cabeceras y políticas) — ver config/security.php
# -----------------------------------------------------------------------------
SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true
CSP_REPORT_ONLY=false
PASSWORD_MIN_LENGTH=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_MINUTES=1

# -----------------------------------------------------------------------------
# DTE / Hacienda — ver config/dte.php (SIN credenciales reales todavía)
# -----------------------------------------------------------------------------
DTE_AMBIENTE=00
DTE_FIRMADOR_URL=http://localhost:8113/firmardocumento
DTE_STORAGE_DISK=local
DTE_API_USER=
DTE_API_PASSWORD=
DTE_CERT_PASSWORD=
DTE_TEST_AUTH_URL=
DTE_TEST_RECEPCION_URL=
DTE_TEST_ANULACION_URL=
DTE_TEST_CONSULTA_URL=
DTE_PROD_AUTH_URL=
DTE_PROD_RECEPCION_URL=
DTE_PROD_ANULACION_URL=
DTE_PROD_CONSULTA_URL=

# Firma local (firmador del MH). DESHABILITADA por defecto. SIN secretos reales aquí:
# el certificado <NIT>.crt va en uploads/ del firmador; la contraseña SOLO en tu .env local.
DTE_FIRMA_ENABLED=false
DTE_FIRMA_NIT=
# DTE_CERT_PASSWORD ya está arriba (déjalo vacío en este archivo de ejemplo).

# Transmisión a Hacienda (recepción). DESHABILITADA por defecto. SIN credenciales reales aquí.
DTE_TRANSMISION_ENABLED=false
# Candados de seguridad ANTES de cualquier transmisión real (mantener así por ahora):
DTE_TRANSMISION_REAL_CONFIRMATION=false
DTE_TRANSMISION_ALLOW_PRODUCTION=false
DTE_TRANSMISION_DRY_RUN=true
# Candado DEDICADO de pruebas: habilita la transmisión real SOLO a apitest cuando
# DTE_TRANSMISION_AMBIENTE=testing. No abre producción. Default false.
DTE_TRANSMISION_TEST_ENABLED=false
# Candado SOLO para `dte:auth-test` (login real contra apitest; NO habilita transmisión):
DTE_AUTH_TEST_REAL_ENABLED=false
# Candado SEPARADO para `dte:auth-test --prod` (login-only contra producción para
# diagnosticar si la credencial es de producción; NO cachea token, NO transmite):
DTE_AUTH_TEST_PROD_ENABLED=false
# El sistema ACTUAL de facturación sigue siendo el oficial en uso.
DTE_SISTEMA_ACTUAL_ACTIVO=true
# Modo de operación del sistema nuevo: paralelo (seguro) | respaldo | principal.
DTE_MODO_OPERACION=paralelo
DTE_TRANSMISION_AMBIENTE=testing
DTE_TRANSMISION_URL=
DTE_TRANSMISION_ENDPOINT_AUTH=/seguridad/auth
DTE_TRANSMISION_ENDPOINT_RECEPCION=/fesv/recepciondte
DTE_TRANSMISION_TIMEOUT=15
DTE_TRANSMISION_USER_AGENT=DulcesLaNegrita-DTE/1.0
DTE_TRANSMISION_USER=
DTE_TRANSMISION_PASSWORD=
DTE_TRANSMISION_TOKEN=

# Credenciales SEPARADAS por ambiente: producción y apitest/homologación son
# cuentas DISTINTAS en Hacienda. Producción cae de vuelta a DTE_TRANSMISION_USER/
# PASSWORD (arriba) mientras no se definan estas; testing NUNCA usa ese fallback
# — si faltan, se bloquea explícito antes de cualquier HTTP.
DTE_PROD_USER=
DTE_PROD_PASSWORD=
DTE_TEST_USER=
DTE_TEST_PASSWORD=

# -----------------------------------------------------------------------------
# MODO MOCK / SIMULADO (solo para probar el flujo en LOCAL, sin producción)
# -----------------------------------------------------------------------------
# Con estos flags el sistema SIMULA firma y respuesta de Hacienda SIN claves
# reales, SIN certificado, SIN credenciales y SIN HTTP real. Los artefactos
# (JWS y sello) se generan FICTICIOS y marcados; NO valen ante Hacienda.
# Dejar en false en el ejemplo; activarlos solo en tu .env local de pruebas.
DTE_FIRMADOR_MOCK=false
MH_MOCK=false

# -----------------------------------------------------------------------------
# INVALIDACIÓN OFICIAL (evento /fesv/anulardte) — anular un DTE ya aceptado
# -----------------------------------------------------------------------------
# Fase C (mock): firma SIMULADA del evento y persistencia, sin transmitir.
DTE_INVALIDACION_MOCK=false
# Fase D (real): candado de la transmisión real a apitest. Debe ser true (además de
# apagar el mock y pasar --transmitir-real --confirmo-invalidar). Nunca abre producción.
DTE_INVALIDACION_REAL_CONFIRMATION=false
# Endpoint de anulación (SIN barra final). Para pruebas: apitest.
DTE_TEST_ANULACION_URL=https://apitest.dtes.mh.gob.sv/fesv/anulardte
# Versión del schema del evento (invalidacion-schema-v3).
DTE_INVALIDACION_VERSION=3
# Overrides SOLO si el MH confirma que difieren de los internos M001/P001 (vacío = internos).
DTE_INVALIDACION_COD_ESTABLE_MH=
DTE_INVALIDACION_COD_PUNTO_VENTA_MH=
# Datos del RESPONSABLE (quien realiza el evento) y del SOLICITANTE (quien lo pide).
# OBLIGATORIOS ante el MH. NO son datos de ejemplo: complételos con datos REALES.
# tipo_doc = CAT-022 (36=NIT, 13=DUI). Si faltan, el preflight BLOQUEA.
DTE_INVALIDACION_RESP_NOMBRE=
DTE_INVALIDACION_RESP_TIPO_DOC=
DTE_INVALIDACION_RESP_NUM_DOC=
DTE_INVALIDACION_SOL_NOMBRE=
DTE_INVALIDACION_SOL_TIPO_DOC=
DTE_INVALIDACION_SOL_NUM_DOC=

# Nombres alternativos sugeridos para el modo mock. En este proyecto ya existen
# con prefijo DTE_* (arriba); se documentan aquí su equivalencia, NO se duplican:
#   DTE_FIRMADOR_ENABLED  -> DTE_FIRMA_ENABLED (interruptor de firma real)
#   DTE_FIRMADOR_URL      -> DTE_FIRMADOR_URL / DTE_FIRMA_URL (URL del firmador)
#   MH_API_URL            -> DTE_TRANSMISION_URL (+ DTE_TEST_RECEPCION_URL)
#   MH_AUTH_URL           -> DTE_TEST_AUTH_URL (+ DTE_TRANSMISION_ENDPOINT_AUTH)
#   MH_USER               -> DTE_TRANSMISION_USER (+ DTE_API_USER)
#   MH_PASSWORD           -> DTE_TRANSMISION_PASSWORD (+ DTE_API_PASSWORD)
#   MH_NIT                -> DTE_FIRMA_NIT

# -----------------------------------------------------------------------------
# Emisor (Dulces La Negrita) — ver config/company.php
# -----------------------------------------------------------------------------
COMPANY_NIT=
COMPANY_NRC=
COMPANY_NAME="Dulces La Negrita"
COMPANY_TRADE_NAME="Dulces La Negrita"
COMPANY_ACTIVITY_CODE=
COMPANY_ACTIVITY_DESC=
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_DEPARTMENT=
COMPANY_MUNICIPALITY=
COMPANY_ADDRESS=

# --- Módulo Prontos Pagos (PPQ) / Gmail (fuente principal de CCF y albaranes) ---
PPQ_GMAIL_ENABLED=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
PPQ_GMAIL_LABEL=Calleja_Albaranes
PPQ_SALA_OC_OFFSET=5
PPQ_SALA_OC_LENGTH=4

# --- Módulo Documentos recibidos (CCF/facturas de proveedores por correo) ---
# Fuente INDEPENDIENTE de Gmail/PPQ: buzón Yahoo por IMAP en SOLO LECTURA (no borra,
# no mueve, no marca leído). Sin credenciales, la revisión queda deshabilitada.
# Las contraseñas van SOLO en .env real, nunca en este ejemplo ni en el repo.
DOCUMENTOS_RECIBIDOS_MAIL_DRIVER=imap
DOCUMENTOS_RECIBIDOS_MAIL_HOST=
DOCUMENTOS_RECIBIDOS_MAIL_PORT=993
DOCUMENTOS_RECIBIDOS_MAIL_ENCRYPTION=ssl
DOCUMENTOS_RECIBIDOS_MAIL_USERNAME=
DOCUMENTOS_RECIBIDOS_MAIL_PASSWORD=
DOCUMENTOS_RECIBIDOS_MAIL_FOLDER=INBOX
