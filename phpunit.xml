<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <!-- DTE: el suite arranca SIEMPRE con firma/transmisión en estado seguro
             (deshabilitado/paralelo), sin importar el .env real de la máquina. Los
             tests que necesitan firmar/transmitir lo habilitan con config()->set. -->
        <!-- Ambiente MH de PRUEBAS (00): el suite no depende del .env real, que puede
             estar en producción (01). Los correlativos de test se crean en ambiente 00. -->
        <env name="DTE_AMBIENTE" value="00"/>
        <!-- Punto de venta predeterminado: el suite arranca SIN configurar (comportamiento
             anterior, auto-resuelve solo si hay un único punto de venta activo), sin importar
             el .env real de la máquina. Los tests del punto de venta predeterminado lo fijan
             explícitamente con config()->set(). -->
        <env name="DTE_PUNTO_VENTA_PREDETERMINADO" value=""/>
        <env name="DTE_FIRMA_ENABLED" value="false"/>
        <env name="DTE_FIRMADOR_MOCK" value="false"/>
        <env name="MH_MOCK" value="false"/>
        <env name="DTE_TRANSMISION_ENABLED" value="false"/>
        <env name="DTE_TRANSMISION_TEST_ENABLED" value="false"/>
        <env name="DTE_TRANSMISION_DRY_RUN" value="true"/>
        <env name="DTE_TRANSMISION_REAL_CONFIRMATION" value="false"/>
        <env name="DTE_TRANSMISION_ALLOW_PRODUCTION" value="false"/>
        <env name="DTE_AUTH_TEST_REAL_ENABLED" value="false"/>
        <env name="DTE_AUTH_TEST_PROD_ENABLED" value="false"/>
        <env name="DTE_MODO_OPERACION" value="paralelo"/>
        <env name="DTE_SISTEMA_ACTUAL_ACTIVO" value="true"/>
        <env name="DTE_TRANSMISION_AMBIENTE" value="testing"/>
        <!-- Documentos recibidos: el suite NUNCA debe conectar al buzón real (Yahoo/IMAP).
             Fuente forzada a 'none' y credenciales vacías, sin importar el .env de la máquina;
             los tests usan un MailboxClient mockeado. -->
        <env name="DOCUMENTOS_RECIBIDOS_MAIL_DRIVER" value="none"/>
        <env name="DOCUMENTOS_RECIBIDOS_MAIL_HOST" value=""/>
        <env name="DOCUMENTOS_RECIBIDOS_MAIL_USERNAME" value=""/>
        <env name="DOCUMENTOS_RECIBIDOS_MAIL_PASSWORD" value=""/>
    </php>
</phpunit>
